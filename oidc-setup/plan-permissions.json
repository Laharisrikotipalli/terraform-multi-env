{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StateBucketAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::lahari-tf-multi-env-state-2026",
        "arn:aws:s3:::lahari-tf-multi-env-state-2026/*"
      ]
    },
    {
      "Sid": "LockTableAccess",
      "Effect": "Allow",
      "Action": ["dynamodb:GetItem", "dynamodb:PutItem", "dynamodb:DeleteItem"],
      "Resource": "arn:aws:dynamodb:us-east-1:511092105426:table/tf-multi-env-lock"
    }
  ]
}
